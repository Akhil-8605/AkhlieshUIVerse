{
  "name": "akhilesh-ui-verse",
  "version": "1.0.1",
  "private": false,
  "description": "A JSON-driven React dashboard framework created and developed by Akhilesh.",
  "main": "./dist/akhilesh-ui-verse.cjs",
  "module": "./dist/akhilesh-ui-verse.js",
  "exports": {
    ".": {
      "import": "./dist/akhilesh-ui-verse.js",
      "require": "./dist/akhilesh-ui-verse.cjs"
    },
    "./style.css": "./dist/akhilesh-ui-verse.css"
  },
  "style": "./dist/akhilesh-ui-verse.css",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "recharts": "^3.8.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@vitejs/plugin-react": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "vite": "^7.1.7",
    "vite-plugin-css-injected-by-js": "^4.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "vite build",
    "prebuild": "npm run clean",
    "build:demo": "react-scripts build",
    "prepublishOnly": "npm run build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
